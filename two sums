class Solution:
    def twoSum(self, nums, target):
        seen = {}
        for i, n in enumerate(nums):
            complement = target - n
            if complement in seen:
                return [seen[complement], i]
            seen[n] = i
s = Solution()
print(s.twoSum([2,7,11,15], 9))  
print(s.twoSum([3,2,4], 6))      
print(s.twoSum([3,3], 6))        
